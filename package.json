{
  "name": "worktracker-desktop",
  "version": "3.0.11",
  "description": "Orbitask Black Edition — project, task, file, and team activity tracking.",
  "author": "Everlasting",
  "private": true,
  "main": "desktop/main.js",
  "homepage": "https://github.com/Everlasting-dev/work-tracking-dashboard",
  "repository": {
    "type": "git",
    "url": "https://github.com/Everlasting-dev/work-tracking-dashboard.git"
  },
  "scripts": {
    "start": "electron .",
    "desktop": "electron .",
    "ui:dev": "npm --prefix orbitrack-ui run dev",
    "ui:build": "npm --prefix orbitrack-ui run build",
    "ui:preview": "npm --prefix orbitrack-ui run preview",
    "pack": "electron-builder --dir",
    "build:orbiflow": "esbuild build-src/orbiflow.jsx --bundle --format=iife --jsx=automatic --minify --outfile=vendor/orbiflow/orbiflow.js",
    "build:orbifun": "esbuild build-src/orbifun.js --bundle --format=iife --minify --outfile=vendor/orbifun/orbifun.js",
    "build:orbicanvas": "esbuild build-src/orbicanvas.jsx --bundle --format=iife --jsx=automatic --minify --outfile=vendor/orbicanvas/orbicanvas.js",
    "dist": "electron-builder --win nsis",
    "dist:win": "electron-builder --win nsis",
    "publish:win": "electron-builder --win nsis --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "@xyflow/react": "^12.11.0",
    "canvas-confetti": "^1.9.4",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "esbuild": "^0.28.1",
    "lucide": "^1.20.0",
    "motion": "^12.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tldraw": "^5.1.1",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31"
  },
  "build": {
    "appId": "com.everlasting.worktracker",
    "productName": "WorkTracker",
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "copyright": "Copyright (c) 2026 Everlasting",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "index.html",
      "app.js",
      "notes.js",
      "chat.js",
      "reports.js",
      "ui.js",
      "bootstrap.js",
      "styles.css",
      "db.js",
      "db-supabase.js",
      "sync.js",
      "sync-v3.js",
      "realtime-sync.js",
      "notification-sounds.js",
      "db-bridge.js",
      "splash-sphere.js",
      "config.js",
      "vendor/**/*",
      "favicon.svg",
      "desktop/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "desktop/main.js"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "WorkTracker",
      "deleteAppDataOnUninstall": false
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Everlasting-dev",
        "repo": "work-tracking-dashboard"
      }
    ]
  }
}
