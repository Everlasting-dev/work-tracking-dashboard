# Discord bot token — from discord.com/developers/applications → Bot → Token
DISCORD_BOT_TOKEN=your-bot-token-here

# Supabase project URL (same as in config.js)
SUPABASE_URL=https://your-project.supabase.co

# Supabase SERVICE ROLE key — Settings → API → service_role (NOT the anon key)
# This bypasses RLS so the bot can insert rows.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Channel mapping: discord-channel-name=app-channel-id,discord-channel-name=app-channel-id
# app-channel-id is either "general" or "project-N" (N = numeric project ID in WorkTracker)
# Examples:
#   general=general            → mirrors #general to the app's General channel
#   logistics=project-3        → mirrors #logistics to WorkTracker project 3's channel
#   team-chat=general,shipments=project-5
CHANNEL_MAP=general=general
