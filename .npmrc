; The island bundles (vendor/orbi*) are pre-built and committed, so the heavy
; React/tldraw/BlockNote/mantine devDependencies only need to *install* (not
; resolve a single shared React version) for electron-builder to package them.
; @mantine/core@9 peer-wants React 19 while we pin React 18 for the other
; islands; allow that mismatch so `npm ci` succeeds in CI.
legacy-peer-deps=true
